{
    "editor.formatOnSave": true,
    "[hcl]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "hashicorp.hcl",
    },
    "[terraform]": {
        "editor.defaultFormatter": "hashicorp.terraform"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.terraform": true
    },
    "files.associations": {
        "bats" : "shellscript"
    }
}